{
  "name": "@yennster/synthetic-data-studio",
  "version": "0.13.1",
  "type": "module",
  "description": "Browser-based 3D synthetic-data studio for Edge Impulse — motion IMU, object detection, visual anomaly, and robotics rover/arm modes with hand tracking, USDZ import, MuJoCo physics, and direct ingestion uploads.",
  "license": "Apache-2.0",
  "author": "yennster",
  "homepage": "https://github.com/yennster/synthetic-data-studio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yennster/synthetic-data-studio.git"
  },
  "bugs": {
    "url": "https://github.com/yennster/synthetic-data-studio/issues"
  },
  "keywords": [
    "edge-impulse",
    "synthetic-data",
    "machine-learning",
    "object-detection",
    "anomaly-detection",
    "accelerometer",
    "hand-tracking",
    "usd",
    "usdz",
    "openusd",
    "three.js",
    "react"
  ],
  "bin": {
    "synthetic-data-studio": "bin/serve.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node bin/serve.mjs",
    "screenshot": "node scripts/screenshot.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node scripts/setup-usdz-wasm.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.35",
    "@mujoco/mujoco": "^3.8.0",
    "@needle-tools/usd": "^0.0.1-61ded11",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/rapier": "^1.5.0",
    "@vercel/analytics": "^2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "puppeteer-core": "^24.43.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "22.x"
  }
}
